# HaloKYC Frontend - Environment Variables
# Copy to .env.local for local development. Never commit secrets.

# Public base URL for the HaloKYC backend API (no trailing slash).
# Used in the browser; must be exposed to the client.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Default verification polling cadence (ms).
NEXT_PUBLIC_VERIFICATION_POLL_MS=2500

# Optional: when true, render the admin console route group.
NEXT_PUBLIC_ENABLE_ADMIN_CONSOLE=true

# Optional: when true, render the subject privacy dashboard (requires backend /api/v1/privacy/* endpoints).
NEXT_PUBLIC_ENABLE_PRIVACY_DASHBOARD=false

# Google OAuth (Sign in with Google).
# Required to enable the Google button on /login.
# The redirect URI must match exactly what is registered in the Google Cloud Console.
# For local dev: http://localhost:3000/login/google/callback
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/login/google/callback